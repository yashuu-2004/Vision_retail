DATABASE_URL=sqlite:///./vision_retail.db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vision_retail

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=INFO
DEBUG=true

KAFKA_BROKERS=localhost:29092
KAFKA_TOPIC_EVENTS=store-events
KAFKA_TOPIC_METRICS=store-metrics
KAFKA_CONSUMER_GROUP=vision-retail

STORAGE_TYPE=local
STORAGE_PATH=./data/storage

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

MODEL_YOLO_PATH=./models/yolov11n.pt
MODEL_OSNET_PATH=./models/osnet_ain_x1_0.pth
DEVICE=cpu

STORE_ID=brigade-bangalore
STORE_LAYOUT_FILE=./data/brigade_road/metadata.json
POS_DATA_FILE=./data/brigade_road/pos.csv
CCTV_FEED_PATH=./data/brigade_road/cameras

ENVIRONMENT=local
SUBMISSION_MODE=false
ENABLE_EVENT_SEED=true
