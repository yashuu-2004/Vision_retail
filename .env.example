# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/vision_retail
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vision_retail

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
DEBUG=false

# Streaming
KAFKA_BROKERS=redpanda:29092
KAFKA_TOPIC_EVENTS=store-events
KAFKA_TOPIC_METRICS=store-metrics
KAFKA_CONSUMER_GROUP=vision-retail

# S3 / Storage
STORAGE_TYPE=local
STORAGE_PATH=/data/storage

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Models
MODEL_YOLO_PATH=/models/yolov11n.pt
MODEL_OSNET_PATH=/models/osnet_ain_x1_0.pth
DEVICE=cpu

# Store Config
STORE_ID=brigade-bangalore
STORE_LAYOUT_FILE=/data/Brigade Road - Store layout.xlsx
POS_DATA_FILE=/data/Brigade_Bangalore_10_April_26.csv
CCTV_FEED_PATH=/data/CCTV Footage

# Challenge
ENVIRONMENT=challenge
SUBMISSION_MODE=true
